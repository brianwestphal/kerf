{
  "width": 760,
  "height": 470,
  "output": "site/public/demos/todomvc.svg",
  "optimize": true,
  "vars": {
    "base": "http://localhost:4188",
    "easeOut": "cubic-bezier(0.215,0.61,0.355,1)",
    "pop": "cubic-bezier(0.175,0.885,0.32,1.275)"
  },
  "frames": [
    {
      "transition": { "type": "cut", "duration": 0 },
      "input": "${base}/todomvc/",
      "waitFor": ".todoapp",
      "wait": 300,
      "actions": [
        { "type": "evaluate", "script": "localStorage.removeItem('kerf-todomvc')" }
      ],
      "duration": 700
    },
    {
      "continue": true,
      "transition": { "type": "cut", "duration": 0 },
      "overlays": [
        { "kind": "typing", "text": "Buy oat milk", "anchor": { "selector": ".new-todo", "at": "left", "dx": 16 }, "fontSize": 17.6, "color": "#1f2937", "caret": true, "bgColor": "#ffffff", "bgWidth": 520, "bgHeight": 30, "speed": 22 }
      ],
      "duration": 1100
    },
    {
      "continue": true,
      "transition": { "type": "cut", "duration": 0 },
      "actions": [
        { "type": "fill", "selector": ".new-todo", "value": "Buy oat milk" },
        { "type": "press", "key": "Enter" },
        { "type": "wait", "ms": 150 }
      ],
      "animations": [
        { "selector": ".todo-list > li:last-child", "property": "translateY", "from": "-10px", "to": "0px", "duration": 260, "easing": "${easeOut}" }
      ],
      "duration": 600
    },
    {
      "continue": true,
      "transition": { "type": "cut", "duration": 0 },
      "overlays": [
        { "kind": "typing", "text": "Read the kerf docs", "anchor": { "selector": ".new-todo", "at": "left", "dx": 16 }, "fontSize": 17.6, "color": "#1f2937", "caret": true, "bgColor": "#ffffff", "bgWidth": 520, "bgHeight": 30, "speed": 22 }
      ],
      "duration": 1100
    },
    {
      "continue": true,
      "transition": { "type": "cut", "duration": 0 },
      "actions": [
        { "type": "fill", "selector": ".new-todo", "value": "Read the kerf docs" },
        { "type": "press", "key": "Enter" },
        { "type": "wait", "ms": 150 }
      ],
      "animations": [
        { "selector": ".todo-list > li:last-child", "property": "translateY", "from": "-10px", "to": "0px", "duration": 260, "easing": "${easeOut}" }
      ],
      "duration": 600
    },
    {
      "continue": true,
      "transition": { "type": "cut", "duration": 0 },
      "overlays": [
        { "kind": "typing", "text": "Ship the animated demos", "anchor": { "selector": ".new-todo", "at": "left", "dx": 16 }, "fontSize": 17.6, "color": "#1f2937", "caret": true, "bgColor": "#ffffff", "bgWidth": 520, "bgHeight": 30, "speed": 22 }
      ],
      "duration": 1200
    },
    {
      "continue": true,
      "transition": { "type": "cut", "duration": 0 },
      "actions": [
        { "type": "fill", "selector": ".new-todo", "value": "Ship the animated demos" },
        { "type": "press", "key": "Enter" },
        { "type": "wait", "ms": 150 }
      ],
      "animations": [
        { "selector": ".todo-list > li:last-child", "property": "translateY", "from": "-10px", "to": "0px", "duration": 260, "easing": "${easeOut}" }
      ],
      "duration": 800
    },
    {
      "continue": true,
      "transition": { "type": "cut", "duration": 0 },
      "actions": [
        { "type": "click", "selector": ".todo-list > li:first-child input.toggle" },
        { "type": "wait", "ms": 200 }
      ],
      "animations": [
        { "selector": ".todo-list > li:first-child", "property": "scale", "from": "0.96", "to": "1", "duration": 320, "easing": "${pop}", "transformOrigin": "left center" }
      ],
      "duration": 3000
    }
  ]
}
