{
  "width": 720,
  "height": 640,
  "output": "site/public/demos/chat.svg",
  "optimize": true,
  "colorScheme": "dark",
  "vars": { "base": "http://localhost:4188" },
  "cursor": "auto",
  "frames": [
    {
      "input": "${base}/chat/",
      "waitFor": ".composer",
      "wait": 300,
      "duration": 1000
    },
    {
      "continue": true,
      "actions": [
        { "type": "click", "selector": ".chips button:nth-of-type(2)" },
        { "type": "wait", "ms": 1100 }
      ],
      "transition": { "type": "crossfade", "duration": 220 },
      "duration": 1100
    },
    {
      "continue": true,
      "waitForGone": ".caret",
      "wait": 250,
      "transition": { "type": "crossfade", "duration": 220 },
      "duration": 1600
    }
  ]
}
