---
// Perf-comparison snapshot, wired to `bench/results.json` (KF-138).
// Source: the OFFICIAL krausest/js-framework-benchmark published results —
// kerf is a merged upstream entry (frameworks/keyed/kerfjs), so it's measured
// on the same reference machine as every competitor. Medians of the per-
// iteration totals; lower is better.
//
// The JSON is regenerated by `node bench/import-krausest.mjs` (which also
// writes `bench/results.md`). Commit the regenerated JSON alongside the
// markdown — the GitHub Pages build doesn't fetch krausest at build time,
// so the file IS the source of truth then. (KF-291)
//
// To change the on-screen subset: edit `SUBSET` below. Keep it small —
// this is a homepage teaser, not the full report.

import data from '../../../bench/results.json';

interface Row {
  framework: string;
  version: string;
  values: (number | null)[];
  highlight?: boolean;
}

// Order matters — this is what the rendered table shows, left-to-right.
const SUBSET_SCENARIOS = [
  'swap rows',
  'remove row',
  'clear 1k',
  'partial update',
  'select row',
] as const;

// Order matters — this is what the rendered table shows, top-to-bottom.
// `key` matches `name` in `bench/results.json` (the framework slug minus
// the `-vX.Y.Z-keyed` suffix); `display` is the on-screen label.
const SUBSET_FRAMEWORKS = [
  { key: 'kerfjs',      display: 'kerf',  highlight: true },
  { key: 'solid',       display: 'Solid' },
  { key: 'vue',         display: 'Vue' },
  { key: 'react-hooks', display: 'React' },
] as const;

const scenarioIndex = new Map(data.scenarios.map((s, i) => [s.label, i]));
const subsetIndices = SUBSET_SCENARIOS.map((label) => {
  const idx = scenarioIndex.get(label);
  if (idx === undefined) {
    throw new Error(`PerfTable: scenario "${label}" not present in bench/results.json (have: ${data.scenarios.map((s) => s.label).join(', ')})`);
  }
  return idx;
});

const scenarios = SUBSET_SCENARIOS;

const rows: Row[] = SUBSET_FRAMEWORKS.map(({ key, display, highlight }) => {
  const fw = data.frameworks.find((f) => f.name === key);
  if (fw === undefined) {
    throw new Error(`PerfTable: framework "${key}" not present in bench/results.json (have: ${data.frameworks.map((f) => f.name).join(', ')})`);
  }
  return {
    framework: display,
    version: fw.version,
    values: subsetIndices.map((i) => fw.values[i]),
    highlight,
  };
});

const best = scenarios.map((_, col) => {
  const nums = rows.map(r => r.values[col]).filter((n): n is number => n !== null);
  return Math.min(...nums);
});

const captured = data.capturedAt !== null ? data.capturedAt.slice(0, 10) : 'unknown';
---

<figure class="perf-table" role="group" aria-labelledby="perf-table-caption">
  <table>
    <caption id="perf-table-caption">
      Keyed list operations — median ms, lower is better
      <span class="perf-meta">(krausest js-framework-benchmark · {captured})</span>
    </caption>
    <thead>
      <tr>
        <th scope="col">Framework</th>
        {scenarios.map(s => <th scope="col">{s}</th>)}
      </tr>
    </thead>
    <tbody>
      {rows.map(row => (
        <tr class:list={['perf-row', { highlight: row.highlight }]}>
          <th scope="row">
            <span class="perf-fw">{row.framework}</span>
            <span class="perf-ver">{row.version}</span>
          </th>
          {row.values.map((v, col) => (
            <td class:list={{ 'is-best': v !== null && v === best[col] }}>
              {v === null ? '—' : v.toFixed(1)}
            </td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
  <p class="perf-foot">
    Bold = fastest in column. Official numbers from the
    <a href="https://krausest.github.io/js-framework-benchmark/current.html">krausest js-framework-benchmark</a>
    (kerf is a listed entry) — full table + every scenario in
    <a href="https://github.com/brianwestphal/kerf/blob/main/bench/results.md">bench/results.md</a>.
  </p>
</figure>

<style>
  .perf-table {
    margin: 1.5rem 0 2rem;
    overflow-x: auto;
  }

  .perf-table table {
    width: 100%;
    border-collapse: collapse;
    font-variant-numeric: tabular-nums;
    font-size: 0.95rem;
  }

  .perf-table caption {
    caption-side: top;
    text-align: left;
    padding: 0 0 0.6rem;
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .perf-table .perf-meta {
    display: block;
    font-weight: 400;
    font-size: 0.85em;
    color: var(--sl-color-gray-3);
    margin-top: 0.15rem;
  }

  .perf-table thead th {
    text-align: right;
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid var(--sl-color-gray-5);
    font-weight: 600;
    color: var(--sl-color-gray-2);
    white-space: nowrap;
  }

  .perf-table thead th:first-child {
    text-align: left;
  }

  .perf-table tbody th {
    text-align: left;
    padding: 0.55rem 0.75rem;
    font-weight: 500;
    border-bottom: 1px solid var(--sl-color-gray-6);
    white-space: nowrap;
  }

  .perf-table tbody td {
    text-align: right;
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid var(--sl-color-gray-6);
  }

  .perf-table .perf-fw {
    font-weight: 600;
  }

  .perf-table .perf-ver {
    margin-left: 0.4rem;
    font-size: 0.85em;
    color: var(--sl-color-gray-3);
    font-weight: 400;
  }

  .perf-table tr.highlight th,
  .perf-table tr.highlight td {
    background: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
    border-bottom-color: color-mix(in srgb, var(--sl-color-accent) 35%, transparent);
  }

  .perf-table tr.highlight .perf-fw {
    color: var(--sl-color-accent-high);
  }

  .perf-table td.is-best {
    font-weight: 700;
  }

  .perf-table .perf-foot {
    margin: 0.6rem 0 0;
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
  }
</style>
